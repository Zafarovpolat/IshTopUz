rules_version = '2';

// IshTop.Uz Firestore Security Rules
// Стратегия: всё серверное (Admin SDK) минует правила; правила защищают
// от прямых обращений клиентского SDK. Клиент может только читать публичные
// данные (профили, проекты) и свои собственные документы.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isClient(userId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(userId)) &&
        get(/databases/$(database)/documents/users/$(userId)).data.userType == 'client';
    }

    function isFreelancer(userId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(userId)) &&
        get(/databases/$(database)/documents/users/$(userId)).data.userType == 'freelancer';
    }

    // ---------- users ----------
    // Публичная часть профиля видна всем (для талантов/профилей),
    // но писать может только владелец; чувствительные поля (wallet, email,
    // phone) правила на клиенте запрещают — они обновляются только
    // через Admin SDK (Server Actions).
    match /users/{userId} {
      allow read: if true;

      allow create: if isOwner(userId);

      // Запрещаем клиентский апдейт чувствительных полей.
      allow update: if isOwner(userId)
        && !('wallet' in request.resource.data.diff(resource.data).affectedKeys())
        && !('email' in request.resource.data.diff(resource.data).affectedKeys())
        && !('phone' in request.resource.data.diff(resource.data).affectedKeys())
        && !('userType' in request.resource.data.diff(resource.data).affectedKeys())
        && !('passwordSet' in request.resource.data.diff(resource.data).affectedKeys())
        && !('isVerified' in request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if false; // удаление только админом

      // Портфолио — публичное чтение, писать только владелец.
      match /portfolio/{itemId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Saved (сохранённые проекты/фрилансеры) — только владелец.
      match /saved/{savedId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ---------- projects ----------
    // Публичный каталог: все проекты читаются всеми.
    // Писать может только владелец-клиент.
    match /projects/{projectId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.clientId == request.auth.uid
        && isClient(request.auth.uid);

      allow update: if isSignedIn()
        && resource.data.clientId == request.auth.uid;

      allow delete: if isSignedIn()
        && resource.data.clientId == request.auth.uid;

      // Proposals: видит клиент-владелец проекта И сам фрилансер-автор.
      match /proposals/{proposalId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/projects/$(projectId)).data.clientId == request.auth.uid
          || resource.data.freelancerId == request.auth.uid
        );

        allow create: if isSignedIn()
          && request.resource.data.freelancerId == request.auth.uid
          && isFreelancer(request.auth.uid)
          && get(/databases/$(database)/documents/projects/$(projectId)).data.clientId != request.auth.uid;

        allow update: if isSignedIn() && (
          resource.data.freelancerId == request.auth.uid
          || get(/databases/$(database)/documents/projects/$(projectId)).data.clientId == request.auth.uid
        );

        allow delete: if isSignedIn()
          && resource.data.freelancerId == request.auth.uid;
      }

      // Reviews на проекте — чтение публично, писать только участники.
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn()
          && resource.data.authorId == request.auth.uid;
      }
    }

    // ---------- conversations / messages ----------
    // Чат: читают только участники.
    match /conversations/{conversationId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        allow update: if isSignedIn()
          && resource.data.senderId == request.auth.uid;

        allow delete: if false;
      }
    }

    // ---------- notifications (top-level) ----------
    // Читает только получатель. Писать может только сервер (Admin SDK).
    // Клиент имеет право только помечать isRead = true.
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;

      allow create: if false;

      allow update: if isSignedIn()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      allow delete: if false;
    }

    // ---------- invitations ----------
    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (
        resource.data.clientId == request.auth.uid
        || resource.data.freelancerId == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.clientId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.freelancerId == request.auth.uid
        || resource.data.clientId == request.auth.uid
      );
      allow delete: if isSignedIn()
        && resource.data.clientId == request.auth.uid;
    }

    // ---------- leads / surveys ----------
    // Маркетинговые лиды и опросы — только создание (публичная форма),
    // чтение только через Admin SDK.
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /surveys/{surveyId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ---------- default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
